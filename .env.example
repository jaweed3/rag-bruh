# LLM Provider (set at least one)
NVIDIA_API_KEY=nvapi-your_key_here
GROQ_API_KEY=gsk_your_key_here

# Optional: API key for endpoints (leave empty to disable)
API_KEY=

# Logging: set JSON_LOG=1 for structured JSON (auto in Docker)
JSON_LOG=

# Default infra (no change needed if using docker-compose)
QDRANT_HOST=localhost
QDRANT_PORT=6333
POSTGRES_DSN=postgresql://rag:rag@localhost:5432/rag
REDPANDA_BROKERS=localhost:19092
